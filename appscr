// Main entry point for POST requests (sales & expenses)
function doPost(e) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const params = e.parameters;
    
    if (params.action[0] === 'sale') {
      const result = handleSale(ss, params);
      // Update revenue chart after a sale
      createRevenueChart(ss);
      return result;
    } else if (params.action[0] === 'expense') {
      return handleExpense(ss, params);
    }
    
    throw new Error('Invalid action');
    
  } catch (error) {
    return ContentService.createTextOutput(`ERROR: ${error.message}`);
  }
}

function updateBusinessRevenue(ss, price, commissionRate) {
  const sheet = getOrCreateSheet(ss, 'Business_Revenue', [
    'Date/Time', 'Price', 'Commission Deduction', 'Net Revenue'
  ]);
  
  const commissionAmount = price * commissionRate;
  const netRevenue = price - commissionAmount;
  
  sheet.appendRow([new Date(), price, commissionAmount, netRevenue]);
  sheet.getRange(sheet.getLastRow(), 2, 1, 3).setNumberFormat("$#,##0.00");
}

function handleSale(ss, params) {
  // SalesCount: Daily system with headers: Salesman, Count, Date
  const salesman = params.salesman[0];
  const isOwner = salesman.toLowerCase() === "ryanhuey"; // added owner check
  const cleanUsername = sanitizeSheetName(salesman);
  const countSheet = getOrCreateSheet(ss, 'SalesCount', ['Salesman', 'Count', 'Date']);
  const countData = countSheet.getDataRange().getValues();
  let salesCount = 1;
  let saleDate = new Date();
  let todayStr = saleDate.toDateString();
  
  // Find a row for this salesman with today's date
  let salesmanRow = countData.findIndex(function(row) {
    if (row[0] === salesman) {
      if (row[2] instanceof Date) {
         return row[2].toDateString() === todayStr;
      } else if (typeof row[2] === "string") {
         let parsedDate = new Date(row[2]);
         return parsedDate.toDateString() === todayStr;
      }
    }
    return false;
  });
  
  if (salesmanRow > -1) {
    salesCount = countData[salesmanRow][1] + 1;
    countSheet.getRange(salesmanRow + 1, 2).setValue(salesCount);
  } else {
    countSheet.appendRow([salesman, 1, saleDate]);
  }
  
  // Updated commission logic: owner gets 0% commission, others get a flat 25%
  let commissionRate = isOwner ? 0 : 0.25;

  const salePrice = parseFloat(params.price[0]);
  updateBusinessRevenue(ss, salePrice, commissionRate);

  // Log commission expense for non-owner sales
  if (!isOwner) {
    const commissionExpense = salePrice * commissionRate;
    updateProfitLoss(ss, saleDate, commissionExpense);
  }

  // Personal sheet updates
  const personalSheet = getOrCreateSheet(ss, cleanUsername, 
    ['Date', 'Price', 'Address', 'Commission Rate', 'Total Commission']);
  
  const saleData = isOwner
    ? [saleDate, salePrice, params.address[0], "", ""]
    : [saleDate, salePrice, params.address[0], commissionRate, salePrice * commissionRate];
  
  personalSheet.appendRow(saleData);
  const personalLastRow = personalSheet.getLastRow();
  personalSheet.getRange(personalLastRow, 2).setNumberFormat("$#,##0.00");
  personalSheet.getRange(personalLastRow, 4).setNumberFormat("0%");
  personalSheet.getRange(personalLastRow, 5).setNumberFormat("$#,##0.00");

  // Sales log updates
  const salesLog = ss.getSheetByName('Sales_Log');
  const logLastRow = salesLog.getLastRow() + 1;
  salesLog.appendRow([
    saleDate,
    salesman,
    salePrice,
    params.address[0],
    params.name[0],
    params.phone[0],
    params.start_time[0],
    commissionRate
  ]);
  salesLog.getRange(logLastRow, 8).setNumberFormat("0%");

  // Customer List updates
  const customerSheet = getOrCreateSheet(ss, 'Customer_List', [
    'Date', 'Customer Name', 'Address', 'Phone', 'Sale Amount'
  ]);
  customerSheet.appendRow([
    saleDate,
    params.name[0],
    params.address[0],
    params.phone[0],
    salePrice
  ]);
  customerSheet.getRange(customerSheet.getLastRow(), 5).setNumberFormat("$#,##0.00");

  // Job Sheet updates
  const jobSheet = getOrCreateSheet(ss, 'Job', ['Start time', 'Address', 'Customer Name']);
  jobSheet.appendRow([
    params.start_time[0],
    params.address[0],
    params.name[0]
  ]);

  // Update Event in Main Google Calendar (using customer name and address)
  const calendarId = "56a33d5be4f0d9445ca1e98fd1c468b2fb9c84e418899a8a77e2396e09117915@group.calendar.google.com";
  const calendar = CalendarApp.getCalendarById(calendarId);
  
  if (!calendar) {
    Logger.log("ERROR: Calendar not found.");
    return ContentService.createTextOutput("ERROR: Calendar not found");
  }
  
  // Parse the start time from the provided format (e.g., "1/1 9AM")
  const startTimeStr = params.start_time[0];
  let eventStart;
  try {
    eventStart = parseSaleStartTime(startTimeStr);
  } catch (error) {
    Logger.log("Invalid start time: " + startTimeStr);
    return ContentService.createTextOutput("ERROR: Invalid start time format. Expected format M/D hAM/PM");
  }
  
  const eventEnd = new Date(eventStart.getTime() + 60 * 60000); // Default duration: 1 hour
  const eventDescription = `📍 Address: ${params.address[0]}\n👤 Customer: ${params.name[0]}`;
  
  var events = calendar.getEvents(eventStart, eventEnd);
  if (events.length > 0) {
    var eventToUpdate = events[0];
    eventToUpdate.setTitle("Slot Taken");
    eventToUpdate.setDescription(eventDescription);
    eventToUpdate.setColor("11"); // Red
    Logger.log("Event Updated: " + eventToUpdate.getId());
  } else {
    Logger.log("No event found at the specified time (" + eventStart + ") to update.");
  }

  // Create event in Job Workers Calendar
  const jobWorkersCalendarId = "a17c258909ceef87d6a08e7c6fbcef1cc83c67c91e263b6e68ae9cf93f415550@group.calendar.google.com";
  const jobWorkersCalendar = CalendarApp.getCalendarById(jobWorkersCalendarId);
  if (jobWorkersCalendar) {
    const jobWorkersEventDescription = `📍 Address: ${params.address[0]}\n👤 Customer: ${params.name[0]}`;
    jobWorkersCalendar.createEvent("Job Worker", eventStart, eventEnd, {description: jobWorkersEventDescription});
  } else {
    Logger.log("Job Workers calendar not found.");
  }

  // Recalculate the summary rows
  updatePersonalCommission(personalSheet);
  updateBusinessNetRevenue(ss);
  updateIncomeReport(ss);
  
  // Schedule immediate email notification 10 seconds after this sale is recorded.
  ScriptApp.newTrigger('sendSaleEmail')
           .timeBased()
           .after(10000)
           .create();
  
  // --- Schedule a follow-up email 6 months later ---
  let followUpDate = new Date(saleDate);
  followUpDate.setMonth(followUpDate.getMonth() + 6);
  // Create a unique key for this follow-up record
  let followUpId = "followUp_" + saleDate.getTime() + "_" + Math.floor(Math.random() * 10000);
  let saleDetails = {
    customerName: params.name[0],
    salePrice: salePrice,
    address: params.address[0],
    serviceDate: saleDate.toISOString(),
    followUpDate: followUpDate.toISOString()
  };
  PropertiesService.getScriptProperties().setProperty(followUpId, JSON.stringify(saleDetails));
  // Schedule the trigger to run at the follow-up date
  ScriptApp.newTrigger('sendFollowUpEmail')
           .timeBased()
           .at(followUpDate)
           .create();
  
  const message = isOwner 
      ? `Success|Sale logged (Owner, Sale #${salesCount}) and Calendar Events Updated`
      : `Success|Commission: ${(commissionRate * 100).toFixed(0)}% (Sale #${salesCount}) and Calendar Events Updated`;
  return ContentService.createTextOutput(message);
}

// This function sends an immediate email notification about a new sale.
function sendSaleEmail() {
  var emailAddress = "ryan@hueysexteriorcleaning.com";
  var subject = "New Sale Recorded";
  var body = "A new sale has been recorded in your spreadsheet at " + new Date() + ".\nPlease check the details in your spreadsheet.";
  MailApp.sendEmail(emailAddress, subject, body);
}

// This function sends a follow-up reminder email when a sale is 6 months old.
// After sending the email, the associated entry is removed from the script properties.
function sendFollowUpEmail() {
  var scriptProperties = PropertiesService.getScriptProperties();
  var allProperties = scriptProperties.getProperties();
  var now = new Date();
  for (var key in allProperties) {
    if (key.indexOf("followUp_") === 0) {
      try {
        var saleDetails = JSON.parse(allProperties[key]);
        var followUpDate = new Date(saleDetails.followUpDate);
        if (now >= followUpDate) {
          var emailAddress = "ryan@hueysexteriorcleaning.com";
          var subject = "Follow-Up Reminder: Service on " + new Date(saleDetails.serviceDate).toLocaleDateString();
          var body = "Reminder to follow up with the customer:\n\n" +
                     "Customer Name: " + saleDetails.customerName + "\n" +
                     "Sale Price: $" + parseFloat(saleDetails.salePrice).toFixed(2) + "\n" +
                     "Address: " + saleDetails.address + "\n" +
                     "Previous Service Date: " + new Date(saleDetails.serviceDate).toLocaleDateString() + "\n\n" +
                     "Please contact the customer for a follow-up service.";
          MailApp.sendEmail(emailAddress, subject, body);
          // Remove this follow-up record so it isn't sent again.
          scriptProperties.deleteProperty(key);
        }
      } catch (e) {
        Logger.log("Error processing follow-up key " + key + ": " + e);
      }
    }
  }
}

function parseSaleStartTime(timeStr) {
  var regex = /^(\d{1,2})\/(\d{1,2})\s+(\d{1,2})(?::(\d{2}))?\s*(AM|PM)$/i;
  var match = timeStr.match(regex);
  if (!match) {
    throw new Error("Invalid start time format. Expected format: M/D hAM/PM");
  }
  var month = parseInt(match[1], 10);
  var day = parseInt(match[2], 10);
  var hour = parseInt(match[3], 10);
  var minute = match[4] ? parseInt(match[4], 10) : 0;
  var meridiem = match[5].toUpperCase();

  if (meridiem === "PM" && hour < 12) {
    hour += 12;
  }
  if (meridiem === "AM" && hour === 12) {
    hour = 0;
  }

  var now = new Date();
  var year = now.getFullYear();
  return new Date(year, month - 1, day, hour, minute);
}

function handleExpense(ss, params) {
  const username = (params.user && params.user[0]) ? params.user[0] : "Unknown";
  const expenseDesc = params.expense[0];  
  const expenseAmount = parseFloat(params.price[0]);
  const receiptUrl = (params.receipt && params.receipt[0]) ? params.receipt[0] : '';
  
  const expSheet = getOrCreateSheet(ss, 'Expense_Log', ['Date', 'User', 'Expense', 'Price', 'Receipt URL']);
  expSheet.appendRow([new Date(), username, expenseDesc, expenseAmount, receiptUrl]);
  expSheet.getRange(expSheet.getLastRow(), 4).setNumberFormat("$#,##0.00");
  
  if (receiptUrl) {
    let row = expSheet.getLastRow();
    expSheet.getRange(row, 5).setFormula(`=HYPERLINK("${receiptUrl}", "View Receipt")`);
  }

  updateProfitLoss(ss, new Date(), expenseAmount);
  
  return ContentService.createTextOutput(`Success|Expense logged: $${expenseAmount.toFixed(2)}`);
}

function updateProfitLoss(ss, date, expense) {
  const sheet = getOrCreateSheet(ss, 'Profit_Loss', ['Date', 'Total Revenue', 'Expense Amount', 'Net Profit']);
  const revenueFormula = '=INDEX(Business_Revenue!D:D, MATCH("Total Net Revenue", Business_Revenue!A:A, 0))';
  sheet.appendRow([date, revenueFormula, expense, '']);
  const lastRow = sheet.getLastRow();
  sheet.getRange(lastRow, 4).setFormula(`=B${lastRow}-C${lastRow}`);
  sheet.getRange(lastRow, 2, 1, 3).setNumberFormat("$#,##0.00");
}

function getTotalNetRevenue(ss) {
  const sheet = getOrCreateSheet(ss, 'Business_Revenue', ['Date/Time', 'Price', 'Commission Deduction', 'Net Revenue']);
  const values = sheet.getDataRange().getValues();
  let total = 0;
  
  for (let i = 1; i < values.length; i++) {
    if (typeof values[i][0] === 'string' && values[i][0].toLowerCase().includes('total net revenue')) {
      continue;
    }
    let netRev = parseFloat(values[i][3]);
    if (!isNaN(netRev)) {
      total += netRev;
    }
  }
  return total;
}

function sanitizeSheetName(name) {
  return name.replace(/[\\\/\?\*:\[\]]/g, '_').substring(0, 100).trim() || 'Unknown_Salesperson';
}

function getOrCreateSheet(ss, sheetName, headers) {
  let sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
    if (headers) {
      sheet.appendRow(headers);
      if (sheetName === 'Profit_Loss') {
        sheet.getRange(2, 2, 1000, 3).setNumberFormat("$#,##0.00");
      }
      if (sheetName === 'Customer_List') {
        sheet.getRange(2, 5, 1000, 1).setNumberFormat("$#,##0.00");
      }
    }
  }
  return sheet;
}

// ----------------- New Summary Functions -----------------

function updatePersonalCommission(personalSheet) {
  // For owner (ryanhuey) skip commission summary
  if (personalSheet.getName().toLowerCase() === "ryanhuey") {
    return;
  }
  
  const dataRange = personalSheet.getDataRange();
  const values = dataRange.getValues();
  
  for (let i = values.length; i >= 2; i--) {
    let cellValue = personalSheet.getRange(i, 1).getValue();
    if (typeof cellValue === 'string' && cellValue.toLowerCase().includes('total commission')) {
      personalSheet.deleteRow(i);
    }
  }
  
  const lastRow = personalSheet.getLastRow();
  personalSheet.appendRow(['Total Commission', '', '', '', '=SUM(E2:E' + lastRow + ')']);
  personalSheet.getRange(personalSheet.getLastRow(), 5).setNumberFormat("$#,##0.00");
}

function updateBusinessNetRevenue(ss) {
  const sheet = getOrCreateSheet(ss, 'Business_Revenue', ['Date/Time', 'Price', 'Commission Deduction', 'Net Revenue']);
  const dataRange = sheet.getDataRange();
  const values = dataRange.getValues();
  
  for (let i = values.length; i >= 2; i--) {
    let cellValue = sheet.getRange(i, 1).getValue();
    if (typeof cellValue === 'string' && cellValue.toLowerCase().includes('total net revenue')) {
      sheet.deleteRow(i);
    }
  }
  
  const lastRow = sheet.getLastRow();
  sheet.appendRow(['Total Net Revenue', '', '', '=SUM(D2:D' + lastRow + ')']);
  sheet.getRange(sheet.getLastRow(), 4).setNumberFormat("$#,##0.00");
}

/**
 * updateIncomeReport creates or clears the "Income_Report" sheet
 * and calculates total net revenue grouped by day, week, and month.
 */
function updateIncomeReport(ss) {
  const reportSheet = getOrCreateSheet(ss, "Income_Report", []);
  reportSheet.clear();
  
  const revenueSheet = getOrCreateSheet(ss, 'Business_Revenue', ['Date/Time', 'Price', 'Commission Deduction', 'Net Revenue']);
  const data = revenueSheet.getDataRange().getValues();
  
  const daily = {};
  const weekly = {};
  const monthly = {};
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const dateCell = row[0];
    if (!(dateCell instanceof Date)) continue;
    
    const netRevenue = parseFloat(row[3]);
    if (isNaN(netRevenue)) continue;
    
    const dayStr = dateCell.toDateString();
    daily[dayStr] = (daily[dayStr] || 0) + netRevenue;
    
    const weekStart = new Date(dateCell);
    weekStart.setDate(dateCell.getDate() - dateCell.getDay());
    const weekStr = weekStart.toDateString();
    weekly[weekStr] = (weekly[weekStr] || 0) + netRevenue;
    
    const monthStr = dateCell.getFullYear() + "-" + (dateCell.getMonth() + 1);
    monthly[monthStr] = (monthly[monthStr] || 0) + netRevenue;
  }
  
  reportSheet.appendRow(["Daily Income"]);
  reportSheet.appendRow(["Date", "Income"]);
  const sortedDays = Object.keys(daily).sort((a, b) => new Date(a) - new Date(b));
  sortedDays.forEach(day => {
    reportSheet.appendRow([day, daily[day]]);
  });
  
  reportSheet.appendRow([""]);
  
  reportSheet.appendRow(["Weekly Income"]);
  reportSheet.appendRow(["Week Start (Sunday)", "Income"]);
  const sortedWeeks = Object.keys(weekly).sort((a, b) => new Date(a) - new Date(b));
  sortedWeeks.forEach(week => {
    reportSheet.appendRow([week, weekly[week]]);
  });
  
  reportSheet.appendRow([""]);
  
  reportSheet.appendRow(["Monthly Income"]);
  reportSheet.appendRow(["Month (YYYY-M)", "Income"]);
  const sortedMonths = Object.keys(monthly).sort((a, b) => new Date(a + "-01") - new Date(b + "-01"));
  sortedMonths.forEach(month => {
    reportSheet.appendRow([month, monthly[month]]);
  });
  
  const lastRow = reportSheet.getLastRow();
  if (lastRow > 0) {
    reportSheet.getRange(2, 2, lastRow - 1, 1).setNumberFormat("$#,##0.00");
  }
}

// ----------------- Chart Creation Functions -----------------

function createRevenueChart(ss) {
  const sheet = ss.getSheetByName("Business_Revenue");
  if (!sheet) return;
  
  const lastRow = sheet.getLastRow();
  const dataRange = sheet.getRange("A1:D" + lastRow);
  
  const chart = sheet.newChart()
    .setChartType(Charts.ChartType.BAR)
    .addRange(dataRange)
    .setPosition(2, 6, 0, 0)
    .setOption('title', 'Business Revenue')
    .build();
    
  sheet.getCharts().forEach(function(existingChart) {
    sheet.removeChart(existingChart);
  });
  sheet.insertChart(chart);
}

// ----------------- Customer History Functions -----------------

function onOpen() {
  SpreadsheetApp.getUi()
      .createMenu("Customer Tools")
      .addItem("View Customer History", "viewCustomerHistory")
      .addToUi();
}

function viewCustomerHistory() {
  var ui = SpreadsheetApp.getUi();
  var response = ui.prompt("Customer History", "Enter the customer's name:", ui.ButtonSet.OK_CANCEL);
  if (response.getSelectedButton() == ui.Button.OK) {
    var customerName = response.getResponseText();
    var htmlContent = getCustomerHistoryHTML(customerName);
    if (htmlContent === "") {
      ui.alert("No records found for customer: " + customerName);
    } else {
      var htmlOutput = HtmlService.createHtmlOutput(htmlContent)
                        .setTitle("Service History for " + customerName)
                        .setWidth(600)
                        .setHeight(400);
      ui.showModalDialog(htmlOutput, "Service History for " + customerName);
    }
  }
}

function getCustomerHistoryHTML(customerName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Customer_List");
  if (!sheet) {
    return "";
  }
  var data = sheet.getDataRange().getValues();
  var html = "<table border='1' cellpadding='5' cellspacing='0'><tr>";
  for (var j = 0; j < data[0].length; j++) {
    html += "<th>" + data[0][j] + "</th>";
  }
  html += "</tr>";
  var found = false;
  for (var i = 1; i < data.length; i++) {
    if (data[i][1].toString().toLowerCase() === customerName.toLowerCase()) {
      found = true;
      html += "<tr>";
      for (var j = 0; j < data[i].length; j++) {
        html += "<td>" + data[i][j] + "</td>";
      }
      html += "</tr>";
    }
  }
  html += "</table>";
  return found ? html : "";
}

// ----------------- Leaderboard Functions -----------------

// Returns the leaderboard text for today's sales.
function getDailyLeaderboard() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  // Ensure the SalesCount sheet exists with headers: Salesman, Count, Date
  const sheet = getOrCreateSheet(ss, "SalesCount", ["Salesman", "Count", "Date"]);
  const data = sheet.getDataRange().getValues();
  const todayStr = new Date().toDateString();
  
  // Filter rows (skip header) where the date is today
  const todaysSales = data.filter((row, index) => {
    if (index === 0) return false; // Skip header
    if (row[2] instanceof Date && row[2].toDateString() === todayStr) {
      return true;
    }
    return false;
  });
  
  // Sort the sales descending by count (index 1)
  todaysSales.sort((a, b) => b[1] - a[1]);
  
  // Get top 3 rows
  const top3 = todaysSales.slice(0, 3);
  
  // Medal emojis for 1st, 2nd, and 3rd
  const medals = ["🥇", "🥈", "🥉"];
  
  // Build the leaderboard string
  const leaderboard = top3.map((row, i) => {
    return `${medals[i]} ${row[0]} - ${row[1]} sales`;
  });
  
  // If no sales found, display a friendly message
  if (leaderboard.length === 0) {
    return "No sales recorded for today yet.";
  }
  
  return leaderboard.join("\n");
}

// Exposes the leaderboard via a simple web endpoint.
// When the URL is called with ?action=leaderboard, it returns the leaderboard text.
function doGet(e) {
  if (e.parameter.action === "leaderboard") {
    const leaderboardText = getDailyLeaderboard();
    return ContentService.createTextOutput(leaderboardText);
  }
  return ContentService.createTextOutput("Invalid request");
}
